@using ShiftService.Kiosk.Models

<div class="chart-wrapper" style="height: 800px; width: 100%;">
    @if (Data != null && Data.hourlyData != null && Data.hourlyData.Any())
    {
        @* Добавили @ref и Options *@
        <ApexChart @ref="chart"
                   TItem="HourlyStatistics"
                   Title="Динамика присутствия сотрудников"
                   XAxisType="XAxisType.Category"
                   Options="chartOptions">

            <!-- Пришли (столбцы вверх) -->
            <ApexPointSeries TItem="HourlyStatistics"
                             Items="Data?.hourlyData"
                             Name="Начали"
                             SeriesType="SeriesType.Bar"
                             XValue="@(e => $"{e.hour:D2}")"
                             YValue="@(e => e.startedCount)" />

            <!-- Ушли (столбцы вниз) -->
            <ApexPointSeries TItem="HourlyStatistics"
                             Items="Data?.hourlyData"
                             Name="Закончили"
                             SeriesType="SeriesType.Bar"
                             XValue="@(e => $"{e.hour:D2}")"
                             YValue="@(e => e.endedCount)" />

            <!-- Активные (линия) -->
            <ApexPointSeries TItem="HourlyStatistics"
                             Items="Data?.hourlyData"
                             Name="Активные"
                             SeriesType="SeriesType.Line"
                             XValue="@(e => $"{e.hour:D2}:00")"
                             YValue="@(e => e.activeCount)" />
        </ApexChart>
    }
    else
    {
        <div class="d-flex justify-content-center align-items-center" style="height: 100%;">
            <div class="spinner-border text-primary" role="status"></div>
            <span class="ms-2">Загрузка данных...</span>
        </div>
    }
</div>

@code {
    [Parameter] public ShiftStatisticsResponse? Data { get; set; }

    private ApexChart<HourlyStatistics>? chart; // Ссылка на экземпляр графика

    // ВАЖНО: Эта функция срабатывает каждый раз, когда меняется параметр Data
    protected override async Task OnParametersSetAsync()
    {
        if (chart != null)
        {
            // Это заставляет JavaScript перерисовать линии с новыми данными
            await chart.UpdateSeriesAsync(true);
        }
    }

    private ApexChartOptions<HourlyStatistics> chartOptions = new()
    {
        Theme = new Theme { Mode = Mode.Dark }, // Тёмная тема лучше для киоска
        Chart = new Chart
        {
            Type = ChartType.Line,
            Stacked = false,
            Toolbar = new Toolbar { Show = false },
            Background = "transparent",
            Animations = new Animations { Enabled = true }, // Плавное обновление
            Height = "350px",
            Width = "100%",
        
        },
        Stroke = new Stroke
        {
            Width = new List<double> { 0, 0, 5 }, 
            Curve = Curve.Smooth
        },

        PlotOptions = new PlotOptions
        {
            Bar = new PlotOptionsBar
            {
                ColumnWidth = "60%"
            }
        },
        Yaxis = new List<YAxis>
        {
            new YAxis
            {
              Min = 0,
              DecimalsInFloat = 0,
              ForceNiceScale = true,
              Labels = new YAxisLabels
              {
                Formatter = "function (val) { return Math.round(val); }"
              }
            }
        },
        DataLabels = new DataLabels
        {
            Enabled = false
        },
        Colors = new List<string>
        {
            "#36B37E", // started
            "#FF8A65", // ended
            "#FFDD44"  // active
        }
    };
}