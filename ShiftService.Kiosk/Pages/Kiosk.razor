@page "/"
@using ShiftService.Kiosk.Models
@using ShiftService.Kiosk.Services
@using System.Globalization
@using ShiftService.Kiosk.Components
@inject KioskApiService Api
@inject IJSRuntime JS
@inject HttpClient Http


<div class="kiosk-container"> 
   
    <HeaderBar />
    <div class="content">
    @if (CurrentMode == KioskMode.Idle)
    {
        @* --- СОСТОЯНИЕ 1: ГЛАВНЫЙ ЭКРАН --- *@
        <div class="screen idle-screen2">
            @*<div class="header">
                <h1 class="display-3">Дата @DateTime.Now.ToString("dd MMMM yyyy 'г.'", new CultureInfo("ru-RU"))</h1>
                <h2 class="display-1 fw-bold">Время: @DateTime.Now.ToString("HH:mm")</h2>
            </div>*@

            <div class="stats-card">
                <h3>Сейчас работают: <span class="badge bg-primary">@activeCount</span></h3>
    
                <div class="chart-container" style="height: 350px;">
                     <HourlyChart Data="todayStats" />
                </div>
            </div>

            <div class="footer-instruction animate-pulse">
                <p>ОТСКАНИРУЙТЕ СВОЙ QR ДЛЯ АВТОРИЗАЦИИ</p>
            </div>
        </div>
    }
    else if (CurrentMode == KioskMode.EmployeeCard)
    {
        @* --- СОСТОЯНИЕ 2: ПРИВЕТСТВИЕ И ВЫБОР ДЕЙСТВИЯ --- *@
        <div class="screen employee-screen text-center">
            <h1 class="mb-4">Здравствуйте, <br /> <strong>@currentEmployee?.fullName</strong></h1>

            @if (currentEmployee != null && !currentEmployee.accessAllowed)
            {
                <div class="alert alert-danger p-5">
                    <h2 class="display-4">ДОСТУП ЗАПРЕЩЕН</h2>
                </div>
                    <button class="btn btn-secondary btn-kiosk mt-4" @onclick="ResetToIdle">ВЫХОД</button>
            }
            else
            {
                <div class="action-buttons d-grid gap-4">
                    @if (isShiftActive)
                    {
                        @* Сценарий 2.2: Завершение *@
                            <div class="info-card mb-3">
                                <p class="h3">Смена открыта: @lastShift?.startTime.ToLocalTime().ToString("ddd, dd.MM.yyyy г. HH:mm", CultureInfo.GetCultureInfo("ru-RU"))</p>
                                <p class="h4 text-info">Длительность: @CalculateDuration()</p>
                        </div>
                        <button class="btn btn-danger btn-kiosk" @onclick="() => HandleEndShift()">ЗАВЕРШИТЬ СМЕНУ</button>
                    }
                    else
                    {
                        @* Сценарий 2.1: Начало *@
                        <button class="btn btn-success btn-kiosk" @onclick="() => HandleStartShift()">НАЧАТЬ СМЕНУ</button>
                    }
                        <button class="btn btn-outline-secondary btn-kiosk" @onclick="ResetToIdle">ОТМЕНА</button>
                </div>
            }
        </div>
    }
    else if (CurrentMode == KioskMode.ProcessResult)
    {
        @* --- СОСТОЯНИЕ 3: РЕЗУЛЬТАТ --- *@
        <div class="screen result-screen text-center">
            <div class="result-icon @(isError ? "text-danger" : "text-success")">
                <i class="bi @(isError ? "bi-x-circle" : "bi-check-circle") display-1"></i>
            </div>
            <h2 class="display-4 my-4">@statusMessage</h2>

                <div class="info-card mb-5">
                <h3>@currentEmployee?.fullName</h3>
                @if (lastShift != null)
                {
                        <p class="h4">Начало смены: @lastShift.startTime.ToLocalTime().ToString("ddd, dd.MM.yyyy г. HH:mm", CultureInfo.GetCultureInfo("ru-RU"))</p>
                    @if (lastShift.endTime != null)
                    {
                            <p class="h4">Завершение смены: @lastShift.endTime.Value.ToLocalTime().ToString("ddd, dd.MM.yyyy г. HH:mm", CultureInfo.GetCultureInfo("ru-RU"))</p>
                            <p class="h4">Длительность смены: @CalculateDurationShift()</p>
                    }
                }
            </div>

            <div class="auto-close-hint">
                Автоматический возврат через <strong>@timerSeconds</strong> сек.
            </div>
                <button class="btn btn-primary  btn-kiosk mt-3" @onclick="ResetToIdle">ГОТОВО</button>
        </div>
    }
    </div>
</div>

@code {
    private KioskMode CurrentMode = KioskMode.Idle;
    private EmployeeResponse? currentEmployee;
    private ShiftResponse? lastShift;
    private ShiftStatisticsResponse? todayStats;
    private int activeCount = 0;

    private string statusMessage = "";
    private bool isError = false;
    private bool isShiftActive = false;
    private int timerSeconds = 5;

    protected override async Task OnInitializedAsync()
    {
        await RefreshGlobalStats();

        // Регистрируем JS-слушатель для QR
        var dotNetHelper = DotNetObjectReference.Create(this);
        await JS.InvokeVoidAsync("setupQrListener", dotNetHelper);

        _ = StartStatsRefreshLoop();
    }

    [JSInvokable]
    public async Task OnQrScanned(string code)
    {
        try
        {
            // 1. Авторизация через POST и вашу модель DTO
            var loginRequest = new QrLoginRequest { QrCode = code };
            var response = await Http.PostAsJsonAsync("api/employees/by-qrcode", loginRequest);

            if (response.IsSuccessStatusCode)
            {
                currentEmployee = await response.Content.ReadFromJsonAsync<EmployeeResponse>();

                if (currentEmployee != null)
                {
                    // 2. Проверяем наличие активной смены через сервис
                    // Если в ApiService нет метода GetCurrentShift, можно использовать GetEmployeeByQrCode, 
                    // если он возвращает статус смены
                    lastShift = await Api.GetCurrentShift(currentEmployee.employeeId);
                    isShiftActive = lastShift != null;

                    CurrentMode = KioskMode.EmployeeCard;
                    isError = false;
                }
            }
            else
            {
                // Если API вернул 404 или 403
                ShowResult("Сотрудник не найден или доступ запрещен", true);
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Ошибка при сканировании: {ex.Message}");
            ShowResult("Ошибка связи с сервером", true);
        }

        StateHasChanged();
    }

    private async Task HandleStartShift()
    {
        try
        {
            lastShift = await Api.StartShift(currentEmployee!.employeeId);
            // Сразу после действия обновляем статистику для графиков
            await RefreshGlobalStats();
            ShowResult("Смена успешно открыта!", false);
        }
        catch (Exception)
        {
            ShowResult("Ошибка открытия смены", true);
        }
    }

    private async Task HandleEndShift()
    {
        try
        {
            lastShift = await Api.EndShift(currentEmployee!.employeeId);
            // Сразу после действия обновляем статистику для графиков
            await RefreshGlobalStats();
            ShowResult("Смена завершена!", false);
        }
        catch (Exception)
        {
            ShowResult("Ошибка закрытия смены", true);
        }
    }

    private void ShowResult(string msg, bool error)
    {
        statusMessage = msg;
        isError = error;
        CurrentMode = KioskMode.ProcessResult;
        StartAutoResetTimer();
    }

    private async Task ResetToIdle()
    {
        CurrentMode = KioskMode.Idle;
        currentEmployee = null;
        lastShift = null;
        await RefreshGlobalStats();
    }

    private async Task RefreshGlobalStats()
    {
        try 
        {
            activeCount = await Api.GetActiveNowCount();
            todayStats = await Api.GetTodayStatistics();
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Ошибка обновления статистики: {ex.Message}");
        }
    }

    private string CalculateDuration()
    {
        if (lastShift == null) return "0ч 0мин";
        TimeSpan diff = DateTime.UtcNow - lastShift.startTime;
        return $"{(int)diff.TotalHours}ч {diff.Minutes}мин";
    }

    private string CalculateDurationShift()
    {
        if (lastShift == null || lastShift.endTime == null)
            return "0ч 0мин";

        if (lastShift == null) return "0ч 0мин";
        TimeSpan diff = lastShift.endTime.Value - lastShift.startTime;
        return $"{(int)diff.TotalHours}ч {diff.Minutes}мин";
    }

    private async Task StartAutoResetTimer()
    {
        timerSeconds = 15;
        while (timerSeconds > 0 && CurrentMode == KioskMode.ProcessResult)
        {
            await Task.Delay(1000);
            timerSeconds--;
            StateHasChanged();
        }
        if (CurrentMode == KioskMode.ProcessResult) await ResetToIdle();
    }

    private async Task StartStatsRefreshLoop()
    {
        while (true)
        {
            await Task.Delay(60000); // 1 минута
            if (CurrentMode == KioskMode.Idle)
            {
                await RefreshGlobalStats();
            }
        }
    }
}